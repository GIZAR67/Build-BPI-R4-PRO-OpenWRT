CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_bananapi_bpi-r4-pro-8x=y
CONFIG_TARGET_ROOTFS_INITRAMFS=y
CONFIG_TARGET_ROOTFS_INITRAMFS_SEPARATE=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y

# TUN support (required for amneziawg-go userspace)
CONFIG_PACKAGE_kmod-tun=y

# AmneziaWG
CONFIG_PACKAGE_amneziawg-tools=y
CONFIG_PACKAGE_luci-proto-amneziawg=y
CONFIG_PACKAGE_kmod-amneziawg=y

# Aeonsemi AS21x1x PHY — 10G RJ45 WAN (комбо-порт SFP/RJ45)
# Без драйвера и прошивки PHY порт RJ45 WAN не работает
CONFIG_PACKAGE_kmod-phy-as21xxx=y
CONFIG_PACKAGE_as21xxx-firmware=y

# WireGuard (kernel module + tools)
CONFIG_PACKAGE_kmod-wireguard=y
CONFIG_PACKAGE_wireguard-tools=y
CONFIG_PACKAGE_luci-proto-wireguard=y

# Disable mihomo (build error in feeds/small)
# CONFIG_PACKAGE_mihomo is not set
# CONFIG_PACKAGE_luci-app-mihomo is not set
